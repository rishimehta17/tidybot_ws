        xyz="-0.00368399956502652 -2.80886425230165E-14 -0.00392534377355658"
        rpy="0 0 0" />
      <mass
        value="0.00839137136228641" />
      <inertia
        ixx="4.25866121345343E-07"
        ixy="2.86320297229105E-20"
        ixz="1.07876607393902E-06"
        iyy="6.27737349321984E-06"
        iyz="-5.63806305516144E-21"
        izz="5.90185560004822E-06" />
    </inertial>
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://drift_tidybot/meshes/right_arm_gripper_right_finger_link.STL" />
      </geometry>
      <material
        name="">
        <color
          rgba="1 1 1 1" />
      </material>
    </visual>
    <collision>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://drift_tidybot/meshes/right_arm_gripper_right_finger_link.STL" />
      </geometry>
    </collision>
  </link>
  <joint
    name="right_arm_gripper_right_finger_joint"
    type="revolute">
    <origin
      xyz="-0.045833 -0.006 -0.037407"
      rpy="0 1.2088 0" />
    <parent
      link="right_arm_gripper_right_gear_link" />
    <child
      link="right_arm_gripper_right_finger_link" />
    <axis
      xyz="0 -1 0" />
    <limit
      lower="-1.57"
      upper="1.57"
      effort="0"
      velocity="0" />
    <mimic
      joint="right_arm_gripper_left_gear_joint"
      multiplier="-1"
      offset="0" />
  </joint>
  <link
    name="right_arm_gripper_right_link_link">
    <inertial>
      <origin
        xyz="-4.77566179934996E-08 -0.00999999999998102 7.43052458451743E-09"
        rpy="0 0 0" />
      <mass
        value="0.00429882746791787" />
      <inertia
        ixx="5.37101085452201E-08"
        ixy="-1.06789017080596E-21"
        ixz="5.20117682793753E-13"
        iyy="2.41160922199763E-06"
        iyz="2.11758236813575E-22"
        izz="2.37996529506525E-06" />
    </inertial>
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://drift_tidybot/meshes/right_arm_gripper_right_link_link.STL" />
      </geometry>
      <material
        name="">
        <color
          rgba="1 1 1 1" />
      </material>
    </visual>
    <collision>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://drift_tidybot/meshes/right_arm_gripper_right_link_link.STL" />
      </geometry>
    </collision>
  </link>
  <joint
    name="right_arm_gripper_right_link_joint"
    type="revolute">
    <origin
      xyz="-0.01584 0.006 -0.036762"
      rpy="0 -0.021485 0" />
    <parent
      link="right_arm_gripper_right_gear_link" />
    <child
      link="right_arm_gripper_right_link_link" />
    <axis
      xyz="0 -1 0" />
    <limit
      lower="-1.57"
      upper="1.57"
      effort="0"
      velocity="0" />
    <mimic
      joint="right_arm_gripper_left_gear_joint"
      multiplier="-1"
      offset="0" />
  </joint>


  <gazebo reference="front_left_wheel_link">
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
  </gazebo>
  <gazebo reference="front_right_wheel_link">
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
  </gazebo>
  <gazebo reference="rear_left_wheel_link">
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
  </gazebo>
  <gazebo reference="rear_right_wheel_link">
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
  </gazebo>

  <gazebo>
    <plugin filename="libgazebo_ros_diff_drive.so" name="diff_drive">
      <num_wheel_pairs>2</num_wheel_pairs>
      <left_joint>front_left_wheel_joint</left_joint>
      <right_joint>front_right_wheel_joint</right_joint>
      <left_joint>rear_left_wheel_joint</left_joint>
      <right_joint>rear_right_wheel_joint</right_joint>
      <wheel_separation>0.53</wheel_separation>
      <wheel_diameter>0.15</wheel_diameter>
      <max_wheel_torque>20</max_wheel_torque>
      <max_wheel_acceleration>1.0</max_wheel_acceleration>
      <command_topic>cmd_vel</command_topic>
      <odometry_topic>odom</odometry_topic>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_link</robot_base_frame>
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>true</publish_wheel_tf>
      <update_rate>50</update_rate>
    </plugin>
  </gazebo>

  <gazebo>
    <plugin name="gazebo_ros_control" filename="libgazebo_ros_control.so">
      <robotNamespace>/</robotNamespace>
    </plugin>
  </gazebo>

  <gazebo>
    <plugin filename="libgazebo_ros2_control.so" name="gazebo_ros2_control">
      <parameters>$(find drift_tidybot)/config/controllers.yaml</parameters>
    </plugin>
  </gazebo>
  <gazebo>
    <plugin name="mimic_left_arm_gripper_right_link_joint"
      filename="libroboticsgroup_gazebo_mimic_joint_plugin.so">
      <joint>left_arm_gripper_left_gear_joint</joint>
      <mimicJoint>left_arm_gripper_right_link_joint</mimicJoint>
      <multiplier>-1.0</multiplier>
      <offset>0.0</offset>
    </plugin>
  </gazebo>

  <gazebo>
    <plugin name="mimic_left_arm_gripper_right_gear_joint"
      filename="libroboticsgroup_gazebo_mimic_joint_plugin.so">
      <joint>left_arm_gripper_left_gear_joint</joint>
      <mimicJoint>left_arm_gripper_right_gear_joint</mimicJoint>
      <multiplier>1.0</multiplier>
      <offset>0.0</offset>
    </plugin>
  </gazebo>

  <gazebo>
    <plugin name="mimic_left_arm_gripper_left_link_joint"
      filename="libroboticsgroup_gazebo_mimic_joint_plugin.so">
      <joint>left_arm_gripper_left_gear_joint</joint>
      <mimicJoint>left_arm_gripper_left_link_joint</mimicJoint>
      <multiplier>1.0</multiplier>
      <offset>0.0</offset>
    </plugin>
  </gazebo>
  <gazebo>
    <plugin name="mimic_right_arm_gripper_right_link_joint"
      filename="libroboticsgroup_gazebo_mimic_joint_plugin.so">
      <joint>right_arm_gripper_left_gear_joint</joint>
      <mimicJoint>right_arm_gripper_right_link_joint</mimicJoint>
      <multiplier>-1.0</multiplier>
      <offset>0.0</offset>
    </plugin>
  </gazebo>

  <gazebo>
    <plugin name="mimic_right_arm_gripper_right_gear_joint"
      filename="libroboticsgroup_gazebo_mimic_joint_plugin.so">
      <joint>right_arm_gripper_left_gear_joint</joint>
      <mimicJoint>right_arm_gripper_right_gear_joint</mimicJoint>
      <multiplier>1.0</multiplier>
      <offset>0.0</offset>
    </plugin>
  </gazebo>

  <gazebo>
    <plugin name="mimic_right_arm_gripper_left_link_joint"
      filename="libroboticsgroup_gazebo_mimic_joint_plugin.so">
      <joint>right_arm_gripper_left_gear_joint</joint>
      <mimicJoint>right_arm_gripper_left_link_joint</mimicJoint>
      <multiplier>1.0</multiplier>
      <offset>0.0</offset>
    </plugin>
  </gazebo>


  <ros2_control name="GazeboSystem" type="system">
    <hardware>
      <plugin>gazebo_ros2_control/GazeboSystem</plugin>
    </hardware>

    <joint name="left_arm_shoulder_joint">
      <command_interface name="position" />
      <state_interface name="position">
        <param name="initial_value">-1.0</param>
      </state_interface>
    </joint>

    <joint name="left_arm_elbow_joint">
      <command_interface name="position" />
      <state_interface name="position">
        <param name="initial_value">1.57</param>
      </state_interface>
    </joint>

    <joint name="left_arm_wrist_joint">
      <command_interface name="position" />
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
    </joint>
    <joint name="left_arm_gripper_left_gear_joint">
      <command_interface name="position" />
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
    </joint>

    <joint name="left_arm_gripper_right_gear_joint">
      <command_interface name="position" />
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
    </joint>

    <joint name="left_arm_gripper_left_link_joint">
      <command_interface name="position" />
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
    </joint>

    <joint name="left_arm_gripper_right_link_joint">
      <command_interface name="position" />
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
    </joint>


    <joint name="right_arm_shoulder_joint">
      <command_interface name="position" />
      <state_interface name="position">
        <param name="initial_value">-1.0</param>
      </state_interface>
    </joint>

    <joint name="right_arm_elbow_joint">
      <command_interface name="position" />
      <state_interface name="position">
        <param name="initial_value">1.57</param>
      </state_interface>
    </joint>

    <joint name="right_arm_wrist_joint">
      <command_interface name="position" />
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
    </joint>
    <joint name="right_arm_gripper_left_gear_joint">
      <command_interface name="position" />
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
    </joint>

    <joint name="right_arm_gripper_right_gear_joint">
      <command_interface name="position" />
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
    </joint>

    <joint name="right_arm_gripper_left_link_joint">
      <command_interface name="position" />
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
    </joint>

    <joint name="right_arm_gripper_right_link_joint">
      <command_interface name="position" />
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
    </joint>


    <!--  -->

  </ros2_control>


  <gazebo reference="lidar_link">
    <material>Gazebo/Red</material>

    <sensor name="laser" type="ray">
      <pose> 0 0 0 0 0 0 </pose>
      <visualize>true</visualize>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>360</samples>
            <min_angle>-3.14</min_angle>
            <max_angle>3.14</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.3</min>
          <max>12</max>
        </range>
      </ray>
      <plugin name="laser_controller" filename="libgazebo_ros_ray_sensor.so">
        <ros>
          <argument>~/out:=scan</argument>
        </ros>
        <output_type>sensor_msgs/LaserScan</output_type>
        <frame_name>lidar_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>


  <!-- <link name="camera_link_optical"></link>
  <joint name="camera_optical_joint" type="fixed">
    <parent link="camera_link" />
    <child link="camera_link_optical" />
    <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708" />
  </joint> -->


  <gazebo reference="camera_link">
    <material>Gazebo/Red</material>

    <sensor name="camera" type="camera">
      <pose> 0 0 0 0 0 0 </pose>
      <visualize>true</visualize>
      <update_rate>10</update_rate>
      <camera>
        <horizontal_fov>1.089</horizontal_fov>
        <image>
          <format>R8G8B8</format>
          <width>640</width>
          <height>480</height>
        </image>
        <clip>
          <near>0.05</near>
          <far>8.0</far>
        </clip>
      </camera>
      <plugin name="camera_controller" filename="libgazebo_ros_camera.so">
        <frame_name>camera_link_optical</frame_name>
      </plugin>
    </sensor>
  </gazebo>

</robot>